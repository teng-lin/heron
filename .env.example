# Copy to `.env` (which is gitignored) and fill in real values.
# Heron reads these via `std::env::var` at runtime; missing values
# usually fall back to a stub or skip the integration.

# ── LLM backends ──────────────────────────────────────────────────────

# Anthropic Messages API (heron-llm). Required for real summarization;
# without it heron-llm uses the stub backend.
ANTHROPIC_API_KEY=

# ── v2 bot driver: Recall.ai spike ────────────────────────────────────

# Required for the Recall spike per docs/build-vs-buy-decision.md.
# Get one from https://recall.ai (sign in → API keys).
RECALL_API_KEY=

# Region. `us` (default) or `eu` — must match the region your Recall
# account was created in. Wrong region returns 401.
RECALL_REGION=us

# Optional: override the base URL (for proxies, tunnels, or testing
# against a Recall mock). Leave unset to use the region-default URL.
# RECALL_BASE_URL=https://us-east-1.recall.ai

# ── Integration toggles ───────────────────────────────────────────────
# Each is a boolean-ish flag — set to "1" to enable real backend
# instead of the stub. Off-by-default so `cargo test` stays hermetic.

HERON_WHISPERKIT_INTEGRATION=
HERON_SHERPA_INTEGRATION=
HERON_PROCESS_TAP_REAL=
HERON_MIC_CAPTURE_REAL=
HERON_ZOOM_RUNNING=

# ── Model paths (optional overrides) ──────────────────────────────────
# Heron-doctor will create these under ~/Library/Application Support
# if unset; override here for testing against custom model bundles.

# HERON_WHISPERKIT_MODEL_DIR=
# HERON_SHERPA_MODEL_DIR=

# ── Process tap target (optional) ─────────────────────────────────────
# Override the default Zoom bundle ID for the system-audio process tap.
# Useful for testing against Meet (us.us.zoom.xos vs com.google.meet etc).

# HERON_PROCESS_TAP_BUNDLE_ID=us.zoom.xos

.DS_Store

# Rust
target/
Cargo.lock.user
*.rs.bk

# Swift package build artifacts (per swift/eventkit-helper/.build etc.)
swift/*/.build/

# Tauri
apps/*/src-tauri/target/
apps/*/dist/
apps/*/node_modules/

# Node
node_modules/
.pnpm-store/
.vite/

# Playwright e2e artifacts (issue #191)
apps/*/test-results/
apps/*/playwright-report/
apps/*/playwright/.cache/

# Secrets / local config
.env
.env.local
settings.local.toml
*.key

# Editor / OS
.idea/
.vscode/
*.swp
*.swo

# Local vault / recordings (never commit user data)
/heron-vault/
/recordings/
/transcripts/

# Recall.ai spike artifacts (see crates/heron-bot/examples/recall-spike.rs)
spike-findings.jsonl
disclosure.mp3
*.aiff

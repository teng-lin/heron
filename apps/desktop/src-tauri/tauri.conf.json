{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "heron",
  "version": "0.1.0",
  "identifier": "com.heronnote.heron",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "heron",
        "width": 1180,
        "height": 760,
        "minWidth": 880,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": { "x": 14, "y": 16 }
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; media-src 'self' asset: https://asset.localhost; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "category": "Productivity",
    "shortDescription": "Private, on-device meeting note-taker.",
    "longDescription": "heron records native meeting calls without joining as a bot, transcribes locally, attributes speakers via the meeting app's accessibility surface, and writes a markdown summary into your Obsidian vault.",
    "icon": [
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "14.0",
      "entitlements": "entitlements.plist",
      "frameworks": []
    }
  }
}

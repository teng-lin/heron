{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "heron",
  "version": "0.1.0",
  "identifier": "com.heronnote.heron",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "heron",
        "width": 720,
        "height": 540,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "category": "Productivity",
    "shortDescription": "Private, on-device meeting note-taker.",
    "longDescription": "heron records native meeting calls without joining as a bot, transcribes locally, attributes speakers via the meeting app's accessibility surface, and writes a markdown summary into your Obsidian vault.",
    "icon": [
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "14.0",
      "entitlements": "entitlements.plist",
      "frameworks": []
    }
  }
}
